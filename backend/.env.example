# ==========================
# DOD Healthcare Backend ENV
# ==========================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection String
# Get from: https://cloud.mongodb.com -> Connect -> Drivers
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/dod-healthcare?retryWrites=true&w=majority

# JWT Secret (make this a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_123456

# JWT Expiry
JWT_EXPIRES_IN=7d

# Cloudinary Credentials
# Get from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=747515935252991
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Admin Credentials (first-time setup - change after first login)
ADMIN_EMAIL=admin@dodhealthcare.com
ADMIN_PASSWORD=Admin@123

# Frontend URL (for CORS) - update after deployment
FRONTEND_URL=http://localhost:3000
